{
  "name": "telegram-user-bot",
  "version": "1.0.0",
  "description": "Minimal Telegram bot with user persistence in MSSQL",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "test": "node --test tests/*.test.js",
    "menus:refresh": "node scripts/refresh-bot-menus.js",
    "companies:import-html": "node scripts/import-remote-companies-from-hypercareer-html.js",
    "companies:fix-urls": "node scripts/fix-remote-company-urls.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "telegram",
    "bot",
    "sequelize",
    "mssql",
    "user-persistence"
  ],
  "license": "MIT",
  "devDependencies": {
    "sequelize-cli": "^6.6.2"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@google/genai": "^1.0.0",
    "bull-board": "^1.7.2",
    "bullmq": "^5.78.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.11.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "sequelize": "^6.37.7",
    "tedious": "^19.2.1",
    "telegraf": "^4.16.3"
  }
}
